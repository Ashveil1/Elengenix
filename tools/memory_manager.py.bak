import sqlite3
import os
from datetime import datetime

DB_FILE = "data/elengenix.db"

def init_db():
    os.makedirs(os.path.dirname(DB_FILE), exist_ok=True)
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS discoveries (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            target TEXT,
            finding TEXT,
            timestamp DATETIME
        )
    ''')
    conn.commit()
    conn.close()

def save_learning(target, discovery):
    init_db()
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('INSERT INTO discoveries (target, finding, timestamp) VALUES (?, ?, ?)', 
                   (target, discovery, datetime.now()))
    conn.commit()
    conn.close()

def get_learnings(target):
    init_db()
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('SELECT finding, timestamp FROM discoveries WHERE target = ? ORDER BY timestamp DESC LIMIT 15', (target,))
    rows = cursor.fetchall()
    conn.close()
    
    if not rows:
        return "No previous memory for this target."
    
    return "\n".join([f"[{row[1]}] - {row[0]}" for row in rows])
