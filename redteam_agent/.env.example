# Red Team Agent — Environment Variables
# Copy this file to .env and fill in your keys

# ── Active Provider ─────────────────────────────────────────
# Choose one: gemini | openai | anthropic | nvidia | custom | ollama
ACTIVE_AI_PROVIDER=gemini

# ── API Keys (fill in what you have) ────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=

# ── Custom / OpenAI-compatible provider ──────────────────────
# Any endpoint that supports POST /v1/chat/completions
CUSTOM_API_BASE=
CUSTOM_API_KEY=
