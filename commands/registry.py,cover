! def command(
!     name: str,
!     *,
!     category: str = "general",
!     help_text: str = "",
!     aliases: Optional[List[str]] = None,
!     requires_target: bool = False,
!     requires_auth: bool = False,
!     examples: Optional[List[str]] = None,
