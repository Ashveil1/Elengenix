import os
import json
import subprocess
import shlex
from llm_client import LLMClient
from knowledge_loader import load_knowledge_base
from orchestrator import run_standard_scan
from tools.research_tool import search_web, extract_web_content
from tools.memory_manager import save_learning, get_learnings
from bot_utils import send_telegram_notification

ALLOWED_COMMANDS = [
    "subfinder", "nuclei", "httpx", "katana", "waybackurls", 
    "nmap", "curl", "ls", "cat", "grep", "python3", "python"
]

class ElengenixAgent:
    def __init__(self):
        self.client = LLMClient()
        with open("prompts/system_prompt.txt", "r") as f:
            self.base_prompt = f.read()
        self.knowledge = load_knowledge_base()

    def get_full_prompt(self, target=""):
        memory = get_learnings(target) if target else ""
        tools_desc = """
### 🛠️ TOOLS:
1. {"action": "run_shell", "command": "..."} - Use for: nmap, curl, etc. (Strictly for security tools)
2. {"action": "search_web", "query": "..."} - Research latest CVEs/Techniques.
3. {"action": "read_web_page", "url": "..."} - Extract text from a page.
4. {"action": "run_standard_scan", "target": "..."} - Run full Elengenix pipeline.
5. {"action": "save_memory", "target": "...", "learning": "..."} - Store findings in SQLite.
6. {"action": "finish_hunt", "summary": "..."} - Use this ONLY when you are completely done.
"""
        return f"{self.base_prompt}\n{self.knowledge}\n### PREVIOUS FINDINGS:\n{memory}\n{tools_desc}"

    def execute_tool(self, action_data, callback=None):
        action = action_data.get("action")
        try:
            if action == "run_shell":
                cmd_raw = action_data.get("command")
                args = shlex.split(cmd_raw)
                if args[0] not in ALLOWED_COMMANDS:
                    return f"❌ Command '{args[0]}' is not allowed for safety reasons."
                
                if callback: callback(f"💻 Executing: `{cmd_raw}`")
                result = subprocess.run(args, capture_output=True, text=True, timeout=300)
                return f"STDOUT: {result.stdout}\nSTDERR: {result.stderr}"

            elif action == "finish_hunt":
                summary = action_data.get("summary")
                send_telegram_notification(f"🏁 *Target Hunt Completed!* \n\n{summary}")
                return "SUCCESS_FINISHED"

            elif action == "run_standard_scan":
                target = action_data.get("target")
                run_standard_scan(target)
                return "Scan complete."
            
            # ... (Existing tools: search_web, read_web_page, etc.) ...
            elif action == "save_memory":
                save_learning(action_data.get("target"), action_data.get("learning"))
                return "✅ Learning saved to SQLite."
            elif action == "search_web":
                return str(search_web(action_data.get("query")))
            elif action == "read_web_page":
                return extract_web_content(action_data.get("url"))
        
        except Exception as e:
            return f"❌ Tool Error: {str(e)}"

    def process_query(self, user_input, callback=None, target=""):
        history = f"User: {user_input}"
        send_telegram_notification(f"🧠 *AI Agent Loop Started (Max 15 rounds)*")
        
        for i in range(15): # Increased to 15 rounds
            full_prompt = f"{self.get_full_prompt(target)}\n\nHistory: {history}\n\nDecision (Respond in JSON):"
            response_text = self.client.chat(full_prompt, "")

            if "{" in response_text and "}" in response_text:
                try:
                    json_str = response_text[response_text.find("{"):response_text.rfind("}")+1]
                    action_data = json.loads(json_str)
                    
                    obs = self.execute_tool(action_data, callback)
                    if obs == "SUCCESS_FINISHED":
                        return f"Mission Completed: {action_data.get('summary')}"
                    
                    history += f"\nAgent: {response_text}\nObservation: {obs}"
                    continue
                except: pass
            
            return response_text
