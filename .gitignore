# ═══════════════════════════════════════════════════════
# Elengenix Git Ignore Configuration
# ═══════════════════════════════════════════════════════

# User-specific config (NEVER COMMIT)
config.yaml
.env
.env.*
MEMORY.md

# But track the examples
!config.yaml.example
!.env.example
!MEMORY.md.example

# Reports and discovered data
reports/
data/*.db
data/*.db-wal
data/*.db-shm
data/*.log
data/scans/
data/wordlists/
data/vector_memory/
elengenix.db
*.db-wal
*.db-shm

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env

# OS files
.DS_Store
Thumbs.db

# Session files
data/sessions/
data/governance_audit.db

# Scan artifacts (output files at repo root only)
/*.txt
/*.json

# Generated runtime data
logs/
response.html
