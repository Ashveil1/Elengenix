# ═══════════════════════════════════════════════════════
# Elengenix Git Ignore Configuration
# ═══════════════════════════════════════════════════════

# User-specific config (NEVER COMMIT)
config.yaml
.env
.env.*
MEMORY.md

# But track the examples
!config.yaml.example
!.env.example
!MEMORY.md.example

# Reports and discovered data
reports/
data/*.db
data/*.log
data/scans/
data/wordlists/
elengenix.db

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env

# OS files
.DS_Store
Thumbs.db
security_agent 