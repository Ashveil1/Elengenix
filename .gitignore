# ═══════════════════════════════════════════════════════
# Elengenix Git Ignore Configuration
# ═══════════════════════════════════════════════════════

# User-specific config (NEVER COMMIT)
config.yaml
.env
.env.*

# But track the examples
!config.yaml.example
!.env.example

# Reports and discovered data
reports/
data/elengenix.db
data/*.log

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env

# OS files
.DS_Store
Thumbs.db
