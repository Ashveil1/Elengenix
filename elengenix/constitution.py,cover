>     principle: ConstitutionalPrinciple
>     description: str
>     severity: str  # critical, high, medium, low
>     remediation_hint: str
>     evidence: Dict[str, Any]
  
  
> @dataclass
> class ConstitutionalRuling:
>     """คำพิพากษาศาลรัฐธรรมนูญ"""
